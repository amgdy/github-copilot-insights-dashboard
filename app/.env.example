# Copilot Insights — Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/copilot_insights

# GitHub Personal Access Token
# Required scopes: manage_billing:copilot, read:org
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub organization slug
GITHUB_ORG=your-org

# Admin password for the Settings page (minimum 8 characters)
ADMIN_PASSWORD=changeme123

# Auto-sync interval in minutes (default: 360 = every 6 hours)
# Set to 0 to disable auto-sync
SYNC_INTERVAL_MINUTES=360
